# AI Image Workbench configuration.
#
# Docker production mode normally leaves the VITE URLs empty so the browser calls the same Studio domain:
#   /api, /login, /v1/images/*, /v1/responses, /v1/chat/completions
# Nginx then proxies those requests to AI_GATEWAY_UPSTREAM.

# OpenAI-compatible account/profile API. Optional for local-only deployments.
VITE_AI_GATEWAY_BASE_URL=
# OpenAI-compatible model/generation API. Optional when using same-domain Docker proxy.
VITE_AI_GATEWAY_MODEL_BASE_URL=
# Image route: auto uses /v1/images/generations for text-to-image and /v1/images/edits for reference/Mask flows.
# Set responses only if your upstream explicitly supports image generation through /v1/responses.
VITE_AI_IMAGE_ROUTE=auto
VITE_AI_RESPONSES_MODEL=gpt-5.5
VITE_AI_RESPONSES_PARTIAL_IMAGES=2
VITE_AI_PROMPT_OPTIMIZER_MODEL=
# Optional. Prefer the Studio domain login proxy so redirect returns to your studio domain.
VITE_AI_GATEWAY_LOGIN_URL=/login

# Backward-compatible aliases for older Sub2API deployments.
VITE_SUB2API_BASE_URL=
VITE_SUB2API_GATEWAY_BASE_URL=
VITE_SUB2API_IMAGE_ROUTE=auto
VITE_SUB2API_RESPONSES_MODEL=gpt-5.5
VITE_SUB2API_RESPONSES_PARTIAL_IMAGES=2
VITE_SUB2API_PROMPT_OPTIMIZER_MODEL=
VITE_SUB2API_LOGIN_URL=/login

# Optional comma-separated remote README case sources.
INSPIRATION_SOURCE_URLS=https://raw.githubusercontent.com/EvoLinkAI/awesome-gpt-image-2-prompts/main/README.md,https://raw.githubusercontent.com/YouMind-OpenLab/awesome-gpt-image-2/main/README.md

# Empty means Studio reads /studio-api on the same domain.
VITE_STUDIO_HISTORY_BASE_URL=
# Optional. Left-top back link. Defaults to /.
VITE_STUDIO_BACK_URL=/
# Keep false for the open-source starter templates. Set true only after /studio-api/library is available.
VITE_STUDIO_LIBRARY_AUTH_REQUIRED=false
# Optional local dev proxy target. Lets http://127.0.0.1:5205 call /v1, /api, and /login without browser CORS.
VITE_DEV_AI_GATEWAY_PROXY_TARGET=https://gateway.example.com
# Backward-compatible local dev proxy alias.
VITE_DEV_SUB2API_PROXY_TARGET=

# Docker production deployment.
STUDIO_PORT=8080
# Local mode lets the history/session service run independently of an upstream account system.
# Use gateway when you want /studio-api to authenticate against the upstream /api/v1/auth/me or /api/v1/user/profile.
STUDIO_AUTH_MODE=local
# Existing OpenAI-compatible gateway. On a VPS where the gateway runs on the host at 127.0.0.1:8080,
# keep the Docker default host gateway address below.
AI_GATEWAY_UPSTREAM=http://host.docker.internal:8080
# Backward-compatible alias.
SUB2API_UPSTREAM=http://host.docker.internal:8080
STUDIO_NGINX_CLIENT_MAX_BODY_SIZE=120m
STUDIO_HISTORY_LIMIT=200
STUDIO_SESSION_NODE_LIMIT=80
STUDIO_SESSION_URL_LIMIT=24
STUDIO_SESSION_QUEUE_LIMIT=12
STUDIO_SESSION_MESSAGE_LIMIT=24
STUDIO_JOB_LIMIT=120
STUDIO_JOB_TIMEOUT_MS=2700000
STUDIO_GATEWAY_FETCH_TIMEOUT_MS=2640000
# Per-user server-side generation concurrency. Keep 1 for small upstream pools; raise carefully after account-pool testing.
STUDIO_JOB_CONCURRENCY=1
STUDIO_MAX_BODY_BYTES=100663296
STUDIO_MAX_IMAGE_BYTES=33554432
# Optional protected library mount. Defaults to ./public.
STUDIO_LIBRARY_DIR=./public
STUDIO_LIBRARY_ASSET_DIR=./public/images

# Optional local gateway contract check. Do not commit real customer credentials.
AI_GATEWAY_BASE_URL=https://gateway.example.com
AI_GATEWAY_EMAIL=
AI_GATEWAY_PASSWORD=
# Backward-compatible aliases for older Sub2API-oriented gateway checks.
SUB2API_BASE_URL=https://sub2api.example.com
SUB2API_EMAIL=
SUB2API_PASSWORD=

# Optional VPS history service.
# Production keeps the legacy data path by default so existing history gallery,
# current sessions, queues, generated assets, and protected library files do not
# disappear after upgrading from image-sub2api-studio to AI Image Workbench.
STUDIO_HISTORY_HOST=127.0.0.1
STUDIO_HISTORY_PORT=8787
STUDIO_DATA_DIR=/var/lib/image-sub2api-studio
STUDIO_ALLOWED_ORIGINS=https://studio.example.com
STUDIO_VERSION=1.0.0

# Ops scripts. Use a real login token/API token only on the server shell, not in the repository.
STUDIO_PUBLIC_BASE_URL=https://studio.example.com
STUDIO_HISTORY_BASE_URL=https://studio.example.com
STUDIO_BACKUP_DIR=./backups
STUDIO_BACKUP_TOKEN=
