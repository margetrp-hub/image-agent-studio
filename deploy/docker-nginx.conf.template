server {
  listen 80;
  server_name _;

  root /usr/share/nginx/html;
  index studio.html;
  absolute_redirect off;
  client_max_body_size ${STUDIO_NGINX_CLIENT_MAX_BODY_SIZE};

  gzip on;
  gzip_types text/plain text/css application/javascript application/json image/svg+xml;

  add_header X-Content-Type-Options nosniff always;
  add_header Referrer-Policy same-origin always;
  add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
  add_header X-Robots-Tag "noindex, nofollow, noarchive" always;

  location = / {
    return 302 /studio/;
  }

  location = /studio {
    return 301 /studio/;
  }

  location /studio/ {
    try_files $uri $uri/ /studio.html;
  }

  location /studio/studio-assets/ {
    alias /usr/share/nginx/html/studio-assets/;
    try_files $uri =404;
    access_log off;
    expires 30d;
    add_header Cache-Control "public, max-age=2592000" always;
    add_header X-Content-Type-Options nosniff always;
  }

  location ~ ^/studio/(cases\.json|inspirations\.json|inspiration-sources\.json|style-library\.json|favicon\.svg|demo-canvas-[0-9]+\.svg)$ {
    rewrite ^/studio/(.*)$ /$1 break;
    try_files $uri =404;
  }

  location /studio/images/ {
    return 404;
  }

  location /studio-api/ {
    proxy_pass ${STUDIO_HISTORY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_connect_timeout 30s;
    proxy_set_header Host $host;
    proxy_set_header Origin "";
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /v1/responses {
    proxy_pass ${AI_GATEWAY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 900s;
    proxy_send_timeout 900s;
    proxy_connect_timeout 30s;
    chunked_transfer_encoding on;
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /v1/images/ {
    proxy_pass ${AI_GATEWAY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_read_timeout 900s;
    proxy_send_timeout 900s;
    proxy_connect_timeout 30s;
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /v1/chat/completions {
    proxy_pass ${AI_GATEWAY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
    proxy_connect_timeout 30s;
    chunked_transfer_encoding on;
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /v1/models {
    proxy_pass ${AI_GATEWAY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_connect_timeout 30s;
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /api/ {
    proxy_pass ${AI_GATEWAY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_connect_timeout 30s;
    proxy_set_header Host $proxy_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /login {
    proxy_pass ${AI_GATEWAY_UPSTREAM};
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_connect_timeout 30s;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location / {
    try_files $uri $uri/ =404;
  }
}
