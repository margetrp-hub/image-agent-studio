{
  "name": "image-agent-studio",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "check:deploy": "node scripts/check-deploy-config.mjs",
    "check:providers": "node scripts/check-provider-dispatch.mjs",
    "check:docker": "node scripts/check-docker-compose.mjs",
    "check:docs": "node scripts/check-doc-encoding.mjs",
    "check:html": "node scripts/check-html-entrypoints.mjs",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "check:env": "node scripts/check-env-contract.mjs",
    "check:public-data": "node scripts/check-public-data.mjs",
    "check:css": "node scripts/check-css-cascade-map.mjs",
    "check:source": "node scripts/check-source-encoding.mjs",
    "check:errors": "node scripts/check-error-catalog.mjs",
    "check:repo": "node scripts/check-repo-clean.mjs",
    "check:release": "node scripts/check-release-packages.mjs",
    "check:inspiration-sources": "node scripts/check-inspiration-sources.mjs",
    "audit:readiness": "node scripts/audit-release-readiness.mjs",
    "check:studio-base": "node scripts/check-studio-build-base.mjs",
    "check:studio-build": "npm run build:studio && npm run check:studio-base",
    "check:web-skeleton": "vite build --config apps/web/vite.config.js",
    "check:gateway": "node scripts/check-ai-gateway-contract.mjs",
    "check:sub2api": "node scripts/check-sub2api-contract.mjs",
    "check:server": "node --check apps/server/src/index.js && node --check apps/server/src/server.js && node --check apps/server/src/domain/schema.js && node --check apps/server/src/domain/types.js && node --check apps/server/src/repositories/historyRepository.js && node --check apps/server/src/storage/memoryAdapter.js && node --check apps/server/src/queue/stateMachine.js",
    "check:local": "npm run build && npm run check:studio-build && npm run check:providers && npm run check:deploy && npm run check:docker && npm run check:docs && npm run check:html && npm run check:source && npm run check:i18n && npm run check:env && npm run check:public-data && npm run check:repo && npm run smoke:persistence && npm run smoke:gateway:auth && npm run smoke:history && npm run smoke:history:idb && npm run smoke:projects && npm run smoke:history:queue && npm run smoke:generation:dedupe && npm run smoke:image:route && npm run smoke:newapi:route && npm run smoke:image:edit-route && npm run smoke:session:modes && npm run smoke:references && npm run smoke:provider:security && npm run smoke:composer:layout && npm run smoke:canvas:performance && npm run smoke:canvas:blob-cleanup && npm run smoke:canvas:link && npm run smoke:history:windowing && npm run smoke:inspiration:windowing && npm run smoke:inspiration:reference-flow && npm run smoke:template:windowing && npm run smoke:language:en",
    "history:service": "node scripts/image-agent-studio-history-service.mjs",
    "ops:backup": "node scripts/ops-backup.mjs",
    "ops:restore": "node scripts/ops-restore.mjs",
    "ops:self-check": "node scripts/ops-self-check.mjs",
    "ops:upgrade": "node scripts/ops-upgrade.mjs",
    "ops:prepare-image-library": "node scripts/prepare-image-library.mjs",
    "ops:localize-inspirations": "node scripts/localize-inspiration-assets.mjs",
    "package:release": "node scripts/package-release.mjs && npm run check:release",
    "package:windows": "node scripts/package-windows.mjs",
    "dev": "vite",
    "dev:studio": "vite --open /studio.html",
    "build": "vite build",
    "build:studio": "vite build --base=/studio/",
    "preview": "vite preview",
    "smoke:studio": "node scripts/smoke-studio-page.mjs",
    "smoke:history": "npm exec --yes --package=playwright -- node scripts/smoke-history-session.mjs",
    "smoke:session:isolation": "node scripts/smoke-session-isolation.mjs",
    "smoke:history:idb": "npm exec --yes --package=playwright -- node scripts/smoke-history-indexeddb.mjs",
    "smoke:gateway:auth": "node scripts/smoke-gateway-auth-service.mjs",
    "smoke:projects": "npm exec --yes --package=playwright -- node scripts/smoke-project-session-grouping.mjs",
    "smoke:history:queue": "npm exec --yes --package=playwright -- node scripts/smoke-generation-queue-recovery.mjs",
    "smoke:generation:dedupe": "node scripts/smoke-generation-job-dedupe.mjs",
    "smoke:backup": "node scripts/smoke-backup-restore.mjs",
    "smoke:image:route": "npm exec --yes --package=playwright -- node scripts/smoke-image-generation-route.mjs",
    "smoke:video:route": "npm exec --yes --package=playwright -- node scripts/smoke-video-generation-route.mjs",
    "smoke:newapi:route": "npm exec --yes --package=playwright -- node scripts/smoke-newapi-route.mjs",
    "smoke:public:route": "npm exec --yes --package=playwright -- node scripts/smoke-public-studio-route.mjs",
    "smoke:image:edit-route": "npm exec --yes --package=playwright -- node scripts/smoke-image-edit-route.mjs",
    "smoke:references": "npm exec --yes --package=playwright -- node scripts/smoke-reference-upload-preview.mjs",
    "smoke:session:modes": "npm exec --yes --package=playwright -- node scripts/smoke-current-session-mode-recovery.mjs",
    "smoke:provider:security": "npm exec --yes --package=playwright -- node scripts/smoke-provider-settings-security.mjs",
    "smoke:composer:layout": "npm exec --yes --package=playwright -- node scripts/smoke-composer-layout.mjs",
    "smoke:composer:folded": "npm exec --yes --package=playwright -- node scripts/smoke-composer-folded-state.mjs",
    "smoke:composer:empty": "npm exec --yes --package=playwright -- node scripts/smoke-composer-empty-state.mjs",
    "smoke:generation:confirm": "npm exec --yes --package=playwright -- node scripts/smoke-generation-confirm-dialog.mjs",
    "smoke:canvas:performance": "npm exec --yes --package=playwright -- node scripts/smoke-canvas-performance.mjs",
    "smoke:canvas:blob-cleanup": "npm exec --yes --package=playwright -- node scripts/smoke-canvas-blob-cleanup.mjs",
    "smoke:canvas:link": "npm exec --yes --package=playwright -- node scripts/smoke-canvas-custom-link.mjs",
    "smoke:history:windowing": "npm exec --yes --package=playwright -- node scripts/smoke-history-windowing.mjs",
    "smoke:inspiration:windowing": "npm exec --yes --package=playwright -- node scripts/smoke-inspiration-windowing.mjs",
    "smoke:inspiration:reference-flow": "node scripts/smoke-inspiration-reference-flow.mjs",
    "smoke:inspiration:prompt-zone": "npm exec --yes --package=playwright -- node scripts/smoke-inspiration-prompt-zone.mjs",
    "smoke:community:prompt-flow": "npm exec --yes --package=playwright -- node scripts/smoke-community-prompt-flow.mjs",
    "smoke:template:windowing": "npm exec --yes --package=playwright -- node scripts/smoke-template-windowing.mjs",
    "smoke:language:en": "npm exec --yes --package=playwright -- node scripts/smoke-language-english.mjs",
    "smoke:persistence": "node scripts/smoke-history-service-persistence.mjs",
    "smoke:docker": "node scripts/smoke-docker-runtime.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "^7.28.0",
    "vite": "^8.0.16"
  },
  "description": "Self-hosted image creation workstation for prompts, reference images, canvas history, and OpenAI-compatible generation/editing routes.",
  "main": "apps/desktop/main.mjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margetrp-hub/image-agent-studio.git"
  },
  "keywords": [
    "ai-image",
    "image-generation",
    "image-agent",
    "openai-compatible",
    "gpt-image-2",
    "prompt-workflow",
    "self-hosted"
  ],
  "author": "margetrp-hub",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/margetrp-hub/image-agent-studio/issues"
  },
  "homepage": "https://github.com/margetrp-hub/image-agent-studio#readme",
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.60.0"
  }
}
