{
  "name": "image-agent-studio-theme",
  "version": 1,
  "displayName": {
    "en": "Image Agent Studio",
    "zh-CN": "创作工作台"
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px"
  },
  "radius": {
    "control": "10px",
    "panel": "18px",
    "sheet": "22px",
    "round": "999px"
  },
  "stroke": {
    "hairline": "1px",
    "focus": "2px",
    "canvasLink": "1.25px"
  },
  "typography": {
    "family": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "size": {
      "caption": "12px",
      "body": "14px",
      "bodyLarge": "16px",
      "title": "20px",
      "display": "28px"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "semibold": "650"
    }
  },
  "motion": {
    "quick": "120ms",
    "normal": "180ms",
    "slow": "260ms",
    "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)"
  },
  "themes": {
    "light": {
      "color": {
        "bg": {
          "app": "#f6f7f8",
          "canvas": "#f8fafc",
          "surface": "#ffffff",
          "surfaceMuted": "#f0f4f8",
          "raised": "#ffffff"
        },
        "text": {
          "primary": "#101418",
          "secondary": "#526171",
          "muted": "#7b8794",
          "inverse": "#ffffff"
        },
        "border": {
          "default": "#d7dee7",
          "subtle": "#e8edf3",
          "strong": "#aab7c5"
        },
        "accent": {
          "primary": "#2563eb",
          "primaryHover": "#1d4ed8",
          "secondary": "#10b981",
          "warm": "#f59e0b"
        },
        "status": {
          "success": "#16a34a",
          "warning": "#d97706",
          "danger": "#dc2626",
          "info": "#2563eb"
        },
        "overlay": {
          "scrim": "rgba(15, 23, 42, 0.28)"
        }
      }
    },
    "dark": {
      "color": {
        "bg": {
          "app": "#111315",
          "canvas": "#171a1f",
          "surface": "#1d2127",
          "surfaceMuted": "#252b33",
          "raised": "#242a32"
        },
        "text": {
          "primary": "#f7f8fa",
          "secondary": "#c4ccd6",
          "muted": "#8994a2",
          "inverse": "#101418"
        },
        "border": {
          "default": "#39424f",
          "subtle": "#2d3540",
          "strong": "#5c6877"
        },
        "accent": {
          "primary": "#60a5fa",
          "primaryHover": "#93c5fd",
          "secondary": "#34d399",
          "warm": "#fbbf24"
        },
        "status": {
          "success": "#4ade80",
          "warning": "#fbbf24",
          "danger": "#f87171",
          "info": "#60a5fa"
        },
        "overlay": {
          "scrim": "rgba(0, 0, 0, 0.42)"
        }
      }
    }
  },
  "product": {
    "composer": {
      "collapsedHeight": "72px",
      "expandedMaxWidth": "920px"
    },
    "canvas": {
      "linkStroke": "{stroke.canvasLink}",
      "selectionStroke": "{stroke.focus}"
    },
    "referencePanel": {
      "thumbnailRadius": "{radius.control}"
    },
    "queue": {
      "progressHeight": "6px"
    }
  }
}
